# LLM Shorts — GitHub Actions Secrets
# Add each in: GitHub repo → Settings → Secrets and variables → Actions → New repository secret

# ── YouTube ───────────────────────────────────────────────────────────────────
# Google Cloud Console → APIs → YouTube Data API v3 → OAuth 2.0 Client ID
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret
# Run scripts/auth.py locally once to get this
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# ── Gmail ─────────────────────────────────────────────────────────────────────
GMAIL_ADDRESS=your@gmail.com
# myaccount.google.com → Security → 2-Step → App passwords → create one labeled "LLM Shorts"
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Where review emails go (can be same as GMAIL_ADDRESS, or a different inbox)
NOTIFY_EMAIL=your@gmail.com

# ── GitHub ────────────────────────────────────────────────────────────────────
# github.com → Settings → Developer settings → Personal access tokens (fine-grained)
# Repository access: this repo only
# Permissions: Actions → Read and write
GH_PAT=github_pat_xxxxxxxxxxxxxxxxxxxx
# GH_REPO is set automatically in workflows via ${{ github.repository }}

# ── Security ──────────────────────────────────────────────────────────────────
# Prevents anyone else from triggering approve/reject
# Generate: python3 -c "import secrets; print(secrets.token_hex(20))"
PIPELINE_SECRET=your_random_secret_here
